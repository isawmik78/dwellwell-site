---
import Layout from '../layouts/Layout.astro';
import Cover from '../components/Cover.astro';
import ContractorForm from '../components/ContractorForm.astro';

// Trades drawn only from published scope. Specialist/regulated trades
// (HVAC, electrical, plumbing) are deliberately not listed.
const trades = [
  'General maintenance & handyman',
  'Repairs (interior & exterior)',
  'Residential & common-area cleaning',
  'Landscaping & grounds',
  'Interior & exterior painting',
  'Securing & board-up',
  'Lock changes & property security',
  'Debris removal & cleanouts',
  'Winterisation',
  'Property inspections & condition reporting',
];
---
<Layout
  title="Join as Contractor · DwellWell Property Care"
  description="Apply to join the DwellWell network. We provide coordinated work to vetted field vendors across residential maintenance and property preservation, with clear scope and consistent dispatch on every job."
  active="contractor"
>
  <Cover
    eyebrow="Join as Contractor"
    title="Join the DwellWell network."
    sub="DwellWell provides work to vetted contractors across residential maintenance and property preservation. Clear scope on every job. Consistent dispatch. Apply to join the network."
    titleWidth="16ch"
    subWidth="60ch"
    minHeight="clamp(380px, 46vw, 500px)"
    padTop="clamp(64px, 9vw, 104px)"
    padBottom="clamp(72px, 10vw, 116px)"
  />

  <main>
    <!-- WHAT WORKING WITH DWELLWELL INVOLVES -->
    <section class="container jc-section">
      <div class="section-head" style="margin-bottom:40px;">
        <span class="section-head__rule"></span>
        <div>
          <div class="eyebrow" style="margin-bottom:12px;"><span class="eyebrow__label">What working with us involves</span></div>
          <h2 class="h2" style="max-width:20ch;">Coordinated work, on clear terms</h2>
        </div>
      </div>
      <div class="jc-cards">
        <div class="jc-card">
          <div class="jc-card__icon">
            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="#4A8BB5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 3h7l4 4v14H6V4"></path><path d="M14 3v4h4"></path><path d="M9.5 12h5"></path><path d="M9.5 15.5h5"></path></svg>
          </div>
          <h3 class="h3" style="font-size:20px;margin-bottom:10px;">The job types</h3>
          <p class="muted">Residential maintenance for occupied homes and rentals, and property preservation for vacant and REO assets. Work is scoped per order, not open-ended.</p>
        </div>
        <div class="jc-card">
          <div class="jc-card__icon">
            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="#4A8BB5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 7h11"></path><path d="M4 12h16"></path><path d="M4 17h8"></path><path d="M17 4l3 3-3 3"></path></svg>
          </div>
          <h3 class="h3" style="font-size:20px;margin-bottom:10px;">The work-order process</h3>
          <p class="muted">You receive a scoped work order, confirm and schedule it, complete the work, and submit it for closeout. DwellWell handles the client relationship throughout.</p>
        </div>
        <div class="jc-card">
          <div class="jc-card__icon">
            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="#4A8BB5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="6" width="18" height="14" rx="2"></rect><circle cx="12" cy="13" r="3.2"></circle><path d="M8 6l1.5-2.5h5L16 6"></path></svg>
          </div>
          <h3 class="h3" style="font-size:20px;margin-bottom:10px;">Documentation expectations</h3>
          <p class="muted">Every job is closed out with photos and written confirmation. Clear documentation is part of the work, not an extra.</p>
        </div>
      </div>
    </section>

    <div class="container"><div class="divider"></div></div>

    <!-- TRADES -->
    <section class="container jc-section">
      <div class="jc-split">
        <div>
          <div class="section-head" style="margin-bottom:20px;">
            <span class="section-head__rule" style="min-height:56px;"></span>
            <div>
              <div class="eyebrow" style="margin-bottom:12px;"><span class="eyebrow__label">Trades we're looking for</span></div>
              <h2 class="h2" style="max-width:16ch;">The work we coordinate</h2>
            </div>
          </div>
          <p class="muted" style="max-width:48ch;padding-left:32px;">Experienced in another field-service trade? Apply anyway, and tell us what you do.</p>
        </div>
        <div class="jc-trades">
          {trades.map((t) => (
            <div class="jc-trade">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#4A8BB5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex:0 0 auto;"><path d="M5 12.5 10 17.5 19 6.5"></path></svg>
              <span class="jc-trade__text">{t}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="container"><div class="divider"></div></div>

    <!-- EXPECTATIONS -->
    <section class="container jc-section">
      <div class="section-head" style="margin-bottom:40px;">
        <span class="section-head__rule"></span>
        <div>
          <div class="eyebrow" style="margin-bottom:12px;"><span class="eyebrow__label">What to expect from us</span></div>
          <h2 class="h2" style="max-width:18ch;">The same terms on every job</h2>
        </div>
      </div>
      <div class="jc-exp">
        <div class="jc-exp__row">
          <div class="jc-exp__icon">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#4A8BB5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 3h7l4 4v14H6V4"></path><path d="M14 3v4h4"></path><path d="M9 12h6"></path><path d="M9 15.5h6"></path></svg>
          </div>
          <div>
            <h3 class="h3" style="font-size:18px;margin-bottom:6px;">Clear scope on every job</h3>
            <p class="muted-sm">You know what's expected before you start. No open-ended asks.</p>
          </div>
        </div>
        <div class="jc-exp__row">
          <div class="jc-exp__icon">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#4A8BB5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 8h12"></path><path d="M16 5l3 3-3 3"></path><path d="M20 16H8"></path><path d="M8 13l-3 3 3 3"></path></svg>
          </div>
          <div>
            <h3 class="h3" style="font-size:18px;margin-bottom:6px;">Consistent dispatch</h3>
            <p class="muted-sm">Work orders come through the same coordinated channel each time.</p>
          </div>
        </div>
        <div class="jc-exp__row">
          <div class="jc-exp__icon">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#4A8BB5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="6" width="18" height="14" rx="2"></rect><circle cx="12" cy="13" r="3"></circle></svg>
          </div>
          <div>
            <h3 class="h3" style="font-size:18px;margin-bottom:6px;">Documentation on every job</h3>
            <p class="muted-sm">Tracked, verified, and closed out with photos and written confirmation.</p>
          </div>
        </div>
      </div>
      <div class="jc-standards">
        <p>We work with experienced, professional field vendors who meet our documentation and service standards. Every job is tracked, verified, and closed out with photos and written confirmation.</p>
      </div>
    </section>

    <!-- APPLICATION FORM -->
    <section class="jc-apply">
      <div class="container jc-apply__inner">
        <div class="jc-apply__grid">
          <div>
            <div class="eyebrow" style="margin-bottom:14px;"><span class="eyebrow__label">Contractor application</span></div>
            <h2 class="h2" style="margin-bottom:16px;max-width:16ch;">Apply to join the network</h2>
            <p class="muted" style="max-width:46ch;">Tell us what you do and where you work. We review every application and follow up by email or phone.</p>
          </div>
          <div>
            <ContractorForm trades={trades} />
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .jc-section { padding: clamp(56px, 9vw, 96px) var(--gutter); }
  .divider { height: 0.5px; background: var(--steel-grey); }
  .muted { font-size: 15px; line-height: 1.6; color: var(--cool-slate); margin: 0; }
  .muted-sm { font-size: 14px; line-height: 1.6; color: var(--cool-slate); margin: 0; }

  .jc-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(264px, 1fr)); gap: 20px; }
  .jc-card { padding: 30px; background: var(--cool-white); border: 1px solid var(--steel-grey); border-radius: 8px; }
  .jc-card__icon { width: 56px; height: 56px; border-radius: 8px; background: var(--midnight); display: flex; align-items: center; justify-content: center; margin-bottom: 22px; }

  .jc-split { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: clamp(32px, 6vw, 64px); align-items: start; }
  .jc-trades { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 10px; }
  .jc-trade { display: flex; gap: 12px; align-items: center; padding: 16px 18px; background: var(--cool-white); border: 1px solid var(--steel-grey); border-radius: 8px; }
  .jc-trade__text { font-size: 14px; line-height: 1.4; color: var(--midnight); }

  .jc-exp { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 36px; }
  .jc-exp__row { display: flex; gap: 18px; align-items: flex-start; padding: 24px; background: var(--cool-white); border: 1px solid var(--steel-grey); border-radius: 8px; }
  .jc-exp__icon { width: 48px; height: 48px; border-radius: 8px; background: var(--midnight); display: flex; align-items: center; justify-content: center; flex: 0 0 auto; }
  .jc-standards { border: 0.5px solid var(--steel-grey); border-radius: 8px; padding: 24px 26px; max-width: 760px; }
  .jc-standards p { font-size: 16px; line-height: 1.65; color: var(--midnight); margin: 0; }

  .jc-apply { background: var(--cool-white); border-top: 1px solid var(--steel-blue); }
  .jc-apply__inner { padding: clamp(56px, 9vw, 88px) var(--gutter) clamp(64px, 9vw, 96px); }
  .jc-apply__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: clamp(32px, 6vw, 64px); align-items: start; }
</style>
