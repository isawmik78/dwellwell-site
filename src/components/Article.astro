---
import type { Article } from '../data/articles';

interface Props {
  article: Article;
}
const { article } = Astro.props;
---
<div class="art">
  <!-- COVER (Dark Field, motif 2.8.B) -->
  <section class="art-cover">
    <svg class="art-cover__motif" viewBox="0 0 1440 720" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <g transform="translate(-176.18,-434.30) scale(3.1)">
        <path d="M190.95,391.71 L289.09,216.80 L387.22,391.71" fill="none" stroke="#F2F4F7" stroke-opacity="0.05" stroke-width="29" stroke-linejoin="miter" stroke-linecap="square"></path>
      </g>
    </svg>
    <div class="art-cover__content">
      <div class="eyebrow eyebrow--dark" style="margin-bottom:20px;">
        <a class="eyebrow__label art-cover__back" href="/resources">{article.category}</a>
      </div>
      <h1 class="art-cover__title">{article.title}</h1>
    </div>
    <div class="art-cover__base">
      <div class="art-cover__rule"></div>
      <div class="art-cover__bar"></div>
    </div>
  </section>

  <main>
    <article class="art-body">
      <p class="art-dek">{article.dek}</p>
      <div class="art-divider"></div>

      {article.blocks.map((b) =>
        b.t === 'h2' ? (
          <h2 class="art-h2">{b.c}</h2>
        ) : b.t === 'p' ? (
          <p class="art-p">{b.c}</p>
        ) : b.t === 'callout' ? (
          <div class="art-callout"><p>{b.c}</p></div>
        ) : (
          <ul class="art-ul">
            {b.c.map((it) => (
              <li class="art-ul__item">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#4A8BB5" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-top:4px;flex:0 0 auto;"><path d="M5 12.5 10 17.5 19 6.5"></path></svg>
                <span class="art-ul__text">{it}</span>
              </li>
            ))}
          </ul>
        )
      )}

      {article.related.length > 0 && (
        <div class="art-related">
          <div class="eyebrow" style="margin-bottom:18px;"><span class="eyebrow__label">More from Resources</span></div>
          <div class="art-related__list">
            {article.related.map((r) => (
              <a class="art-related__card" href={`/resources/${r.slug}`}>
                <span class="art-related__title">{r.title}</span>
                <span class="art-related__read">Read →</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </article>
  </main>

  <!-- CTA band -->
  <section class="art-cta">
    <div class="container art-cta__inner">
      <p class="art-cta__title">Have a property that needs this handled?</p>
      <div class="art-cta__btns">
        <a class="btn btn--primary" href="/contact">Start a conversation</a>
        <a class="btn btn--secondary" href="/contact">Request service</a>
      </div>
    </div>
  </section>
</div>

<style>
  .art-cover { position: relative; background: var(--midnight); overflow: hidden; min-height: clamp(360px, 42vw, 460px); display: flex; flex-direction: column; justify-content: center; padding: clamp(56px, 8vw, 96px) 0 clamp(64px, 9vw, 104px); }
  .art-cover__motif { position: absolute; inset: 0; width: 100%; height: 100%; }
  .art-cover__content { position: relative; z-index: 2; max-width: 820px; width: 100%; margin: 0 auto; padding: 0 clamp(20px, 5vw, 40px); }
  .art-cover__back { text-decoration: none; border-bottom: 1px solid transparent; padding-bottom: 1px; transition: border-color 0.15s; }
  .art-cover__back:hover { border-color: var(--steel-blue); }
  .art-cover__back:focus-visible { outline: 2px solid var(--steel-blue); outline-offset: 3px; }
  .art-cover__title { font-family: var(--font-display); font-weight: 600; font-size: clamp(32px, 5.2vw, 48px); line-height: 1.16; color: var(--cool-white); margin: 0; max-width: 22ch; }
  .art-cover__base { position: absolute; left: 0; right: 0; bottom: 0; z-index: 2; }
  .art-cover__rule { height: 1px; background: var(--steel-blue); }
  .art-cover__bar { height: 18px; background: var(--cool-white); }

  .art-body { max-width: 820px; margin: 0 auto; padding: clamp(48px, 7vw, 80px) clamp(20px, 5vw, 40px) clamp(40px, 6vw, 56px); }
  .art-dek { font-family: var(--font-display); font-weight: 600; font-size: clamp(22px, 3vw, 28px); line-height: 1.32; color: var(--midnight); margin: 0 0 14px; max-width: 40ch; }
  .art-divider { height: 0.5px; background: var(--steel-grey); margin: 28px 0 36px; }
  .art-h2 { font-family: var(--font-display); font-weight: 600; font-size: clamp(26px, 3.6vw, 32px); line-height: 1.22; color: var(--midnight); margin: 40px 0 14px; max-width: 30ch; }
  .art-p { font-size: 17px; line-height: 1.68; color: var(--midnight); margin: 0 0 20px; max-width: 72ch; }
  .art-ul { list-style: none; margin: 0 0 24px; padding: 0; display: flex; flex-direction: column; gap: 2px; max-width: 72ch; }
  .art-ul__item { display: flex; gap: 14px; align-items: flex-start; padding: 12px 0; border-bottom: 0.5px solid var(--steel-grey); }
  .art-ul__text { font-size: 16px; line-height: 1.55; color: var(--midnight); }
  .art-callout { border: 0.5px solid var(--steel-blue); border-radius: 8px; padding: 22px 24px; margin: 8px 0 24px; max-width: 72ch; }
  .art-callout p { font-size: 16px; line-height: 1.6; color: var(--midnight); margin: 0; }

  .art-related { margin-top: 48px; padding-top: 32px; border-top: 0.5px solid var(--steel-grey); }
  .art-related__list { display: flex; flex-direction: column; gap: 10px; }
  .art-related__card { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 18px 20px; background: var(--cool-white); border: 1px solid var(--steel-grey); border-radius: 8px; text-decoration: none; transition: border-color 0.15s; }
  .art-related__card:hover { border-color: var(--steel-blue); }
  .art-related__card:focus-visible { outline: 2px solid var(--steel-blue); outline-offset: 2px; }
  .art-related__title { font-weight: 600; font-size: 16px; letter-spacing: -0.01em; color: var(--midnight); }
  .art-related__read { font-weight: 500; font-size: 14px; color: var(--steel-blue-text); flex: 0 0 auto; }

  .art-cta { background: var(--cool-white); border-top: 1px solid var(--steel-blue); }
  .art-cta__inner { padding: clamp(48px, 8vw, 80px) var(--gutter); display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 28px; }
  .art-cta__title { font-family: var(--font-display); font-weight: 600; font-size: clamp(26px, 3.8vw, 36px); line-height: 1.2; color: var(--midnight); margin: 0; max-width: 22ch; }
  .art-cta__btns { display: flex; flex-wrap: wrap; gap: 14px; }
</style>
