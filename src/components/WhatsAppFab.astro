---
/**
 * Floating WhatsApp button, fixed bottom-right on every page.
 * Number is [TBD] at launch; href stays "#" until the WhatsApp link is wired.
 */
---
<a class="wa-fab" href="#" aria-label="Chat with DwellWell on WhatsApp">
  <svg viewBox="0 0 32 32" aria-hidden="true">
    <path fill="#F2F4F7" d="M16 .5C7.4.5.5 7.4.5 16c0 2.8.7 5.5 2.1 7.9L.5 31.5l7.8-2c2.3 1.3 5 1.9 7.7 1.9 8.6 0 15.5-6.9 15.5-15.5S24.6.5 16 .5zm0 28.3c-2.5 0-4.9-.7-7-1.9l-.5-.3-4.6 1.2 1.2-4.5-.3-.5C3.4 20.7 2.7 18.4 2.7 16 2.7 8.7 8.7 2.7 16 2.7S29.3 8.7 29.3 16 23.3 28.8 16 28.8zm8.2-9.9c-.4-.2-2.6-1.3-3-1.4-.4-.1-.7-.2-1 .2s-1.1 1.4-1.4 1.7c-.2.3-.5.3-.9.1-.4-.2-1.9-.7-3.6-2.2-1.3-1.2-2.2-2.6-2.5-3-.3-.4 0-.7.2-.9.2-.2.4-.5.6-.8.2-.3.3-.5.4-.8.1-.3 0-.6 0-.8-.1-.2-1-2.4-1.4-3.3-.4-.9-.7-.7-1-.7h-.8c-.3 0-.8.1-1.2.5-.4.4-1.6 1.5-1.6 3.7s1.6 4.3 1.9 4.6c.2.3 3.2 4.9 7.7 6.8 1.1.5 1.9.8 2.6 1 1.1.3 2.1.3 2.9.2.9-.1 2.6-1.1 3-2.1.4-1 .4-1.9.3-2.1-.1-.2-.4-.3-.8-.5z"/>
  </svg>
</a>

<style>
  .wa-fab {
    position: fixed;
    right: clamp(16px, 3vw, 28px);
    bottom: clamp(16px, 3vw, 28px);
    z-index: 60;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: var(--midnight);
    border: 1px solid var(--steel-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(16, 30, 49, 0.28);
    transition: transform 0.15s;
  }
  .wa-fab:hover { transform: translateY(-2px); }
  .wa-fab:focus-visible { outline: 2px solid var(--steel-blue); outline-offset: 3px; }
  .wa-fab svg { width: 28px; height: 28px; }
</style>
